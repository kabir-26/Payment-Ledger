{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "module": "ESNext",
    "target": "ES2022",
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "types": ["vite/client", "jest"]
  },
  "include": ["src/**/*.js", "src/**/*.jsx", "vite.config.js"]
}
